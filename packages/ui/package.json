{
  "name": "@devlens/ui",
  "version": "1.1.0",
  "description": "DevLens UI Panel - visual issue overlay for browser debugging",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "devlens",
    "crashsense",
    "debug",
    "ui-panel",
    "developer-tools",
    "overlay"
  ],
  "author": "crashsense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crashsense/devlens.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/crashsense/devlens#readme",
  "bugs": {
    "url": "https://github.com/crashsense/devlens/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@devlens/core": "2.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0"
  }
}
