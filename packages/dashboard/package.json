{
  "name": "@devlens/dashboard",
  "version": "2.1.0",
  "type": "module",
  "main": "./dist-lib/index.cjs",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist-lib/index.d.ts",
        "default": "./dist-lib/index.js"
      },
      "require": {
        "types": "./dist-lib/index.d.ts",
        "default": "./dist-lib/index.cjs"
      }
    },
    "./style.css": "./dist-lib/dashboard.css"
  },
  "files": [
    "dist-lib"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:lib",
    "build:spa": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@devlens/core": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
