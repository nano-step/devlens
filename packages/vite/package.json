{
  "name": "@devlens/vite",
  "version": "1.0.0",
  "description": "Vite plugin for DevLens — embedded dashboard at /__devlens/",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "client"
  ],
  "sideEffects": false,
  "scripts": {
    "build:client": "cd ../dashboard && npx vite build --outDir ../vite/client --emptyOutDir",
    "build": "npm run build:client && tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist client",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "devlens",
    "vite-plugin",
    "devtools",
    "debug"
  ],
  "author": "crashsense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crashsense/devlens.git",
    "directory": "packages/vite"
  },
  "homepage": "https://github.com/crashsense/devlens#readme",
  "bugs": {
    "url": "https://github.com/crashsense/devlens/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "sirv": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  }
}
